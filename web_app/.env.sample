# AWS 인증 (프로파일 또는 직접 입력)
AWS_PROFILE=default
AWS_REGION=ap-northeast-2
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Glue 카탈로그
GLUE_DATABASE=opensky-database
GLUE_TABLE=opensky_s3_sink

# Iceberg warehouse S3 경로 (trailing slash 포함)
S3_WAREHOUSE=s3://opensky-jin-data/bronze/flight_states/

# 풀 주기 (초)
PULL_INTERVAL=30
